# Optional systemd environment file for agent_voice.
# Copy to /etc/default/agent-voice and replace the placeholder value.

OPENAI_API_KEY=replace-me
RUST_LOG=info,agent_voice=debug
SPEECH_STT_PROVIDER=openai
SPEECH_TTS_PROVIDER=openai
SHERPA_ONNX_PYTHON_BIN=/opt/agent_voice/.venv/bin/python
SHERPA_ONNX_BRIDGE_SCRIPT=/opt/agent_voice/python/sherpa_onnx_bridge.py
